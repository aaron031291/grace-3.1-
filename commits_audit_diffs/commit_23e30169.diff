+  const statusColor = { red: "#f44336", orange: "#ff9800" };
+
+  return (
+    <div>
+      <div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 16 }}>
+        <h2 style={h2s}>Problems</h2>
