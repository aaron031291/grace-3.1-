+        <button onClick={async () => { await jf(`${B}/api/triggers/scan-and-heal`, { method: "POST" }); load(); }} style={actBtn("#8b5cf6")}>Scan &amp; Heal</button>
+      </div>
+
+      {data && (
+        <div style={{ display: "flex", gap: 12, marginBottom: 16 }}>
+          <div style={{ ...card, padding: "8px 16px", borderLeft: "3px solid #f44336" }}>Critical: <strong style={{ color: "#f44336" }}>{data.critical}</strong></div>
+          <div style={{ ...card, padding: "8px 16px", borderLeft: "3px solid #ff9800" }}>Degrading: <strong style={{ color: "#ff9800" }}>{data.degrading}</strong></div>
+          <div style={{ ...card, padding: "8px 16px" }}>Total: <strong>{data.total}</strong></div>
+        </div>
