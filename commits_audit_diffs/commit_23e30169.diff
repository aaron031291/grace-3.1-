+            <span style={{ fontSize: 11, fontWeight: 700, color: statusColor[p.status] }}>{p.status.toUpperCase()}</span>
+          </div>
+          <div style={{ fontSize: 12, color: "#aaa", marginTop: 4 }}>{p.reason}</div>
+          <div style={{ fontSize: 11, color: "#666", marginTop: 2 }}>
+            {p.total_events} events | {p.errors} errors | Error rate: {(p.error_rate * 100).toFixed(1)}%
+            {p.last_seen && ` | Last seen: ${p.minutes_since?.toFixed(0)}m ago`}
+          </div>
+          {p.dependencies?.length > 0 && (
+            <div style={{ fontSize: 10, color: "#555", marginTop: 2 }}>Dependencies: {p.dependencies.join(", ")}</div>
+          )}
+        </div>
+      ))}
+
+      {data?.problems?.length === 0 && <div style={{ color: "#4caf50", fontSize: 14, padding: 20, textAlign: "center" }}>All components healthy</div>}
+
+      {approvals?.approvals?.length > 0 && (
+        <div style={{ marginTop: 16 }}>
+          <h3 style={h3s}>Pending Approvals</h3>
+          {approvals.approvals.map((a, i) => (
+            <div key={i} style={{ ...card, marginBottom: 6, padding: "10px 14px" }}>
+              <div style={{ fontSize: 13, fontWeight: 700 }}>{a.label}: {a.action}</div>
+              <div style={{ fontSize: 11, color: "#888" }}>{a.reason}</div>
+              <div style={{ display: "flex", gap: 8, marginTop: 8 }}>
