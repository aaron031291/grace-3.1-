# =============================================================================
# GRACE API Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your environment
# IMPORTANT: Never commit .env to version control!

# =============================================================================
# SECURITY SETTINGS (IMPORTANT - CONFIGURE THESE FIRST!)
# =============================================================================

# Production Mode - Set to 'true' in production for stricter security
# Enables: HTTPS-only cookies, HSTS headers, stricter validation
PRODUCTION_MODE=false

# CORS - Comma-separated list of allowed origins
# CRITICAL: Never use "*" in production with credentials!
# Example production: CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Rate Limiting - Protects against DoS and brute force attacks
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_UPLOAD=20/minute
RATE_LIMIT_AI=30/minute

# Session Security
# SESSION_COOKIE_SECURE: Set to 'true' in production (requires HTTPS)
SESSION_COOKIE_SECURE=false

# Security Event Logging
LOG_SECURITY_EVENTS=true

# =============================================================================
# Database Configuration
# =============================================================================

# Database Type: sqlite, postgresql, mysql, mariadb
# Default: sqlite (requires no additional setup)
DATABASE_TYPE=sqlite

# SQLite Configuration
# Path to SQLite database file (default: ./data/grace.db)
DATABASE_PATH=./data/grace.db

# Remote Database Configuration (for PostgreSQL, MySQL, MariaDB)
# Uncomment and configure these when using remote databases

# Database host (default: localhost)
# DATABASE_HOST=localhost

# Database port (optional, uses default port for each database type)
# DATABASE_PORT=5432

# Database username (required for remote databases)
# DATABASE_USER=grace_user

# Database password (required for remote databases)
# DATABASE_PASSWORD=your_secure_password

# Database name (default: grace)
DATABASE_NAME=grace

# Enable SQL query logging (default: false)
# Useful for debugging - shows all SQL statements executed
DATABASE_ECHO=false

# Application Configuration
# =========================

# Ollama Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_LLM_DEFAULT=mistral:7b

# Embedding Configuration
EMBEDDING_DEFAULT=qwen_4b
EMBEDDING_DEVICE=cuda
EMBEDDING_NORMALIZE=true

# Application Settings
DEBUG=false
LOG_LEVEL=INFO
MAX_NUM_PREDICT=512

# =============================================================================
# COMPONENT CONTROL FLAGS
# =============================================================================

# Skip component initialization checks (useful for lightweight/development mode)
# Set to 'true' to disable specific components

# Skip Qdrant vector database check on startup
SKIP_QDRANT_CHECK=false

# Skip Ollama LLM check on startup
SKIP_OLLAMA_CHECK=false

# Skip automatic file ingestion on startup
SKIP_AUTO_INGESTION=false

# Skip embedding model preloading on startup (model will load on first use)
SKIP_EMBEDDING_LOAD=false

# Enable lightweight mode (minimal resource usage)
LIGHTWEIGHT_MODE=false

# Disable Genesis key tracking
DISABLE_GENESIS_TRACKING=false

# =============================================================================
# ERROR HANDLING CONFIGURATION
# =============================================================================

# Suppress ingestion errors (continue processing even if some files fail)
# WARNING: Setting this to 'true' may hide important errors
SUPPRESS_INGESTION_ERRORS=false

# PostgreSQL Example Configuration
# =================================
# Uncomment to use PostgreSQL instead of SQLite
# DATABASE_TYPE=postgresql
# DATABASE_HOST=db.example.com
# DATABASE_PORT=5432
# DATABASE_USER=grace_user
# DATABASE_PASSWORD=your_secure_password
# DATABASE_NAME=grace
# DATABASE_ECHO=false

# MySQL Example Configuration
# ============================
# Uncomment to use MySQL instead of SQLite
# DATABASE_TYPE=mysql
# DATABASE_HOST=db.example.com
# DATABASE_PORT=3306
# DATABASE_USER=grace_user
# DATABASE_PASSWORD=your_secure_password
# DATABASE_NAME=grace
# DATABASE_ECHO=false

# MariaDB Example Configuration
# ==============================
# Uncomment to use MariaDB instead of SQLite
# DATABASE_TYPE=mariadb
# DATABASE_HOST=db.example.com
# DATABASE_PORT=3306
# DATABASE_USER=grace_user
# DATABASE_PASSWORD=your_secure_password
# DATABASE_NAME=grace
# DATABASE_ECHO=false
