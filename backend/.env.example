# =============================================================================
# GRACE API Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your environment
# IMPORTANT: Never commit .env to version control!

# =============================================================================
# SECURITY SETTINGS (IMPORTANT - CONFIGURE THESE FIRST!)
# =============================================================================

# Production Mode - Set to 'true' in production for stricter security
# Enables: HTTPS-only cookies, HSTS headers, stricter validation
PRODUCTION_MODE=false

# CORS - Comma-separated list of allowed origins
# CRITICAL: Never use "*" in production with credentials!
# Example production: CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Rate Limiting - Protects against DoS and brute force attacks
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_UPLOAD=20/minute
RATE_LIMIT_AI=30/minute

# Session Security
# SESSION_COOKIE_SECURE: Set to 'true' in production (requires HTTPS)
SESSION_COOKIE_SECURE=false

# Security Event Logging
LOG_SECURITY_EVENTS=true

# Admin API — Set to enable /api/admin/* (registry, state, reload-config, trigger-diagnostics).
# Use header X-Admin-Token or query ?token=... . Leave empty to disable admin API.
ADMIN_TOKEN=

# =============================================================================
# Database Configuration
# =============================================================================
# DEFAULT: PostgreSQL. Set DATABASE_HOST, DATABASE_USER, DATABASE_PASSWORD (and optionally DATABASE_NAME).
# For local dev without Postgres, set DATABASE_TYPE=sqlite and DATABASE_PATH=./data/grace.db.

# Database Type: postgresql (default), sqlite, mysql, mariadb
DATABASE_TYPE=postgresql

# PostgreSQL (default) — use same host/port/user/password as pgAdmin, stGIS, etc.
# Username is your Postgres role (e.g. postgres), not "localhost".
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_NAME=grace
# Leave empty for local; use "require" for cloud/DigitalOcean
DATABASE_SSLMODE=

# SQLite (only when DATABASE_TYPE=sqlite)
DATABASE_PATH=./data/grace.db

# Enable SQL query logging (default: false)
DATABASE_ECHO=false

# =============================================================================
# Ollama Configuration
# =============================================================================

OLLAMA_URL=http://localhost:11434
OLLAMA_LLM_DEFAULT=qwen2.5:7b

# Per-task local models — pulled on startup. For Qwen 3.5 use qwen3.5:7b in Ollama.
# Note: qwen2.5:32b is not in the default Ollama set; use qwen3:32b or qwen2.5-coder:32b for REASON if needed.
OLLAMA_MODEL_CODE=qwen2.5-coder:7b
OLLAMA_MODEL_REASON=deepseek-r1:7b
OLLAMA_MODEL_FAST=qwen2.5:7b
# Document parse/read (librarian, ingestion). Qwen used by default — no GPT 4.1 or Kimi required.
OLLAMA_MODEL_DOCUMENT=qwen3:32b

# For 16GB VRAM (RTX 4080/5060 Ti 16GB) — use 14B models:
# OLLAMA_MODEL_CODE=qwen2.5-coder:14b        # Better code quality than 7B
# OLLAMA_MODEL_REASON=deepseek-r1:14b        # Better reasoning than 7B
# OLLAMA_MODEL_FAST=qwen2.5:7b               # Fast general tasks

# For 32GB VRAM (RTX 5090) — use larger models:
# OLLAMA_MODEL_CODE=deepseek-coder-v2:16b    # 160K context! Best for complex code
# OLLAMA_MODEL_REASON=deepseek-r1:32b        # Deep chain-of-thought reasoning
# OLLAMA_MODEL_FAST=qwen2.5:14b              # Fast general tasks
# Alternative code model:
# OLLAMA_MODEL_CODE=qwen2.5-coder:32b        # 32K context, highest code quality

# For 64GB+ VRAM (dual GPU) — use largest models:
# OLLAMA_MODEL_CODE=qwen2.5-coder:32b
# OLLAMA_MODEL_REASON=llama3.1:70b-instruct-q4_K_M
# OLLAMA_MODEL_FAST=qwen2.5:32b

# ==================== Cloud LLMs ====================
# Kimi 2.5 (Moonshot AI) — reasoning + document analysis
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2-turbo-preview

# Opus 4.6 (Anthropic Claude) — deep reasoning + audit
OPUS_API_KEY=
OPUS_BASE_URL=https://api.anthropic.com/v1
OPUS_MODEL=claude-sonnet-4-20250514

# OpenAI (used when LLM_PROVIDER=openai)
LLM_API_KEY=
LLM_PROVIDER=ollama
LLM_MODEL=

# =============================================================================
# Hugging Face (optional - higher rate limits and faster model downloads)
# =============================================================================
# Create a token at https://huggingface.co/settings/tokens and set it here.
# HF_TOKEN=
# Or: HUGGING_FACE_HUB_TOKEN=

# =============================================================================
# Embedding Configuration
# =============================================================================

EMBEDDING_DEFAULT=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true

# =============================================================================
# Qdrant Vector Database Configuration
# =============================================================================
# Local: leave QDRANT_URL and QDRANT_API_KEY empty; ensure Qdrant is running (e.g. start_services.bat qdrant).
# Cloud API: set QDRANT_URL and QDRANT_API_KEY in .env to use Qdrant Cloud (no local Qdrant needed).
#   Example: QDRANT_URL=https://xxxxx.gcp.cloud.qdrant.io  QDRANT_API_KEY=your-api-key

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=documents
QDRANT_TIMEOUT=30

# Genesis keys Qdrant collection (provenance search). Must match existing collection vector size or omit to use embedder size.
# If you see "genesis_qdrant_400" or "vector size mismatch", set this to your genesis_keys collection size (e.g. 384 for all-MiniLM-L6-v2).
# GENESIS_VECTOR_SIZE=384
# Disable pushing genesis keys to Qdrant (no provenance search in Qdrant):
# DISABLE_GENESIS_QDRANT_PUSH=1

# Genesis keys Qdrant collection: vector size must match Qdrant Cloud 'genesis_keys' collection.
# Leave unset to use embedding model dimension (recommended). Set to match existing collection if you get 400.
# GENESIS_VECTOR_SIZE=384

# =============================================================================
# Ingestion Configuration
# =============================================================================

INGESTION_CHUNK_SIZE=512
INGESTION_CHUNK_OVERLAP=50
EXCLUDE_GENESIS_FROM_INGESTION=true

# =============================================================================
# Librarian System Configuration
# =============================================================================

LIBRARIAN_AUTO_PROCESS=true
LIBRARIAN_USE_AI=true
LIBRARIAN_DETECT_RELATIONSHIPS=true
LIBRARIAN_AI_CONFIDENCE_THRESHOLD=0.6
LIBRARIAN_SIMILARITY_THRESHOLD=0.7
LIBRARIAN_MAX_RELATIONSHIP_CANDIDATES=20
LIBRARIAN_AI_MODEL=gemma3:4b

# =============================================================================
# SerpAPI Configuration (Web Search)
# =============================================================================

SERPAPI_KEY=
SERPAPI_ENABLED=true
SERPAPI_MAX_RESULTS=5
SERPAPI_AUTO_SCRAPE=true

# Knowledge gap fill: software engineering sources (all optional; no keys except GitHub)
# GITHUB_TOKEN= optional; 60 req/hr without, 5000/hr with token
GITHUB_TOKEN=
GAP_FILL_GITHUB=true
GAP_FILL_STACKOVERFLOW=true
GAP_FILL_ARXIV=true
GAP_FILL_WIKIPEDIA=true
GAP_FILL_HACKERNEWS=true
GAP_FILL_DEVTO=true
GAP_FILL_PYPI=true
GAP_FILL_MDN=true
GAP_FILL_SEMANTIC_SCHOLAR=true
GAP_FILL_NPM=true
GAP_FILL_IETF_RFC=true
# Optional: higher rate limit for Semantic Scholar
SEMANTIC_SCHOLAR_API_KEY=

# =============================================================================
# Application Settings
# =============================================================================

DEBUG=false
LOG_LEVEL=INFO
MAX_NUM_PREDICT=512

# =============================================================================
# COMPONENT CONTROL FLAGS
# =============================================================================

# Skip component initialization checks (useful for lightweight/development mode)
SKIP_QDRANT_CHECK=false
SKIP_OLLAMA_CHECK=false
SKIP_AUTO_INGESTION=false
SKIP_EMBEDDING_LOAD=false
LIGHTWEIGHT_MODE=false
DISABLE_GENESIS_TRACKING=false
DISABLE_CONTINUOUS_LEARNING=false
HEALING_SIMULATION_MODE=false

# =============================================================================
# ERROR HANDLING / SUPPRESSION FLAGS
# =============================================================================

# Suppress errors (continue processing even if some components fail)
# WARNING: Setting these to 'true' may hide important errors
SUPPRESS_INGESTION_ERRORS=false
SUPPRESS_GENESIS_ERRORS=false
SUPPRESS_QDRANT_ERRORS=false
SUPPRESS_EMBEDDING_ERRORS=false

# =============================================================================
# Example Database Configurations
# =============================================================================

# PostgreSQL Example
# DATABASE_TYPE=postgresql
# DATABASE_HOST=db.example.com
# DATABASE_PORT=5432
# DATABASE_USER=grace_user
# DATABASE_PASSWORD=your_secure_password
# DATABASE_NAME=grace

# MySQL Example
# DATABASE_TYPE=mysql
# DATABASE_HOST=db.example.com
# DATABASE_PORT=3306
# DATABASE_USER=grace_user
# DATABASE_PASSWORD=your_secure_password
# DATABASE_NAME=grace

# MariaDB Example
# DATABASE_TYPE=mariadb
# DATABASE_HOST=db.example.com
# DATABASE_PORT=3306
# DATABASE_USER=grace_user
# DATABASE_PASSWORD=your_secure_password
# DATABASE_NAME=grace
