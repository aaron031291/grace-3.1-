import sqlite3
import logging
logger = logging.getLogger(__name__)

db_path = "data/grace.db"
conn = sqlite3.connect(db_path)
cursor = conn.cursor()

# Get a failed page to check if error_message exists
cursor.execute("""
    SELECT url, status, error_message, title
    FROM scraped_pages 
    WHERE status = 'failed'
    ORDER BY id DESC 
    LIMIT 3
""")

pages = cursor.fetchall()
logger.info("Failed pages in database:")
for url, status, error, title in pages:
    logger.info(f"\nURL: {url[:60]}...")
    logger.info(f"Status: {status}")
    logger.info(f"Error: {error}")
    logger.info(f"Title: {title}")

conn.close()
