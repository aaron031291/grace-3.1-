#!/usr/bin/env python3
"""Fix: Re-ingest GDP document and clean up orphaned vectors."""

import sys
import logging
logging.basicConfig(level=logging.INFO)

from settings import settings
from database.connection import DatabaseConnection, DatabaseConfig, DatabaseType
from database.session import initialize_session_factory
from api.file_ingestion import get_file_manager
from vector_db.client import get_qdrant_client
from models.database_models import Document, DocumentChunk
from sqlalchemy.orm import sessionmaker
from pathlib import Path

logger.info("=" * 80)
logger.info("FIX: GDP DOCUMENT RE-INGESTION")
logger.info("=" * 80)

# Initialize database
logger.info("\n1. Initializing database...")
db_type = DatabaseType(settings.DATABASE_TYPE) if settings else DatabaseType.SQLITE
db_config = DatabaseConfig(
    db_type=db_type,
    database=settings.DATABASE_NAME if settings else "grace",
    database_path=settings.DATABASE_PATH if settings else None,
    echo=False,
)
DatabaseConnection.initialize(db_config)
initialize_session_factory()

SessionLocal = sessionmaker(bind=DatabaseConnection.get_engine())
db = SessionLocal()

# Step 1: Check for orphaned vectors
logger.info("\n2. Checking for orphaned vectors...")
orphaned_vector_ids = []
for vector_id in range(2000, 2010):
    chunk = db.query(DocumentChunk).filter(
        DocumentChunk.embedding_vector_id == str(vector_id)
    ).first()
    if not chunk:
        orphaned_vector_ids.append(vector_id)

if orphaned_vector_ids:
    logger.info(f"   Found {len(orphaned_vector_ids)} orphaned vectors: {orphaned_vector_ids}")
    
    # Delete orphaned vectors from Qdrant
    logger.info(f"\n3. Removing orphaned vectors from Qdrant...")
    qdrant = get_qdrant_client()
    try:
        for vector_id in orphaned_vector_ids:
            qdrant.delete_vectors(
                collection_name="documents",
                vector_ids=[vector_id],
            )
        logger.info(f"   ✓ Removed {len(orphaned_vector_ids)} orphaned vectors")
    except Exception as e:
        logger.info(f"   ✗ Error removing vectors: {e}")
else:
    logger.info("   No orphaned vectors found")

# Step 2: Re-ingest GDP document
logger.info("\n4. Re-ingesting GDP document...")
gdp_path = Path("/home/umer/Public/projects/grace_3/backend/knowledge_base/forensic/gdp_volatility.pdf")

if gdp_path.exists():
    logger.info(f"   Found GDP file: {gdp_path}")
    
    # Get file manager
    file_manager = get_file_manager()
    
    # Ingest the file using the ingestion service directly
    from file_manager.file_handler import FileHandler
    
    # Extract text from PDF
    text, error = FileHandler.extract_text(str(gdp_path))
    if error:
        result_obj = type('Result', (), {
            'success': False,
            'error': error,
            'message': f'Extraction failed: {error}'
        })()
    else:
        # Ingest the extracted text
        doc_id, message = file_manager.ingestion_service.ingest_text_fast(
            text_content=text,
            filename=gdp_path.name,
            source=str(file_manager.knowledge_base_path),
            upload_method="file-import",
            source_type="knowledge_base",
            metadata={"file_path": str(gdp_path.relative_to(file_manager.knowledge_base_path))},
        )
        result_obj = type('Result', (), {
            'success': doc_id is not None,
            'error': message if doc_id is None else None,
            'message': message,
            'document_id': doc_id
        })()
    
    result = result_obj
    
    if result.success:
        logger.info(f"   ✓ Re-ingestion successful")
        logger.info(f"     Document ID: {result.document_id}")
        logger.info(f"     Message: {result.message}")
        
        # Verify in database
        doc = db.query(Document).filter(Document.id == result.document_id).first()
        if doc:
            logger.info(f"\n5. Verification:")
            logger.info(f"   ✓ Document found in database")
            logger.info(f"     ID: {doc.id}")
            logger.info(f"     Filename: {doc.filename}")
            logger.info(f"     Status: {doc.status}")
            chunk_count = db.query(DocumentChunk).filter(DocumentChunk.document_id == doc.id).count()
            logger.info(f"     Chunks: {chunk_count}")
    else:
        logger.info(f"   ✗ Re-ingestion failed: {result.error}")
else:
    logger.info(f"   ✗ GDP file not found at {gdp_path}")

logger.info("\n" + "=" * 80)
logger.info("FIX COMPLETE")
logger.info("=" * 80)

db.close()
