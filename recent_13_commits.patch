-        '.pdf': 'documents/pdf',
-        '.csv': 'data/csv',
-        '.json': 'data/json',
-        '.xml': 'data/xml',
-        '.yml': 'configuration',
-        '.yaml': 'configuration',
-        '.toml': 'configuration',
-        '.ini': 'configuration',
-        '.cfg': 'configuration',
-        '.log': 'logs',
-        '.png': 'media/images',
-        '.jpg': 'media/images',
